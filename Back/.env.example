# ─────────────────────────────────────────────
# PAT Backend — Environment Variables
# Copy this file to .env and fill in your values
# NEVER commit .env to git
# ─────────────────────────────────────────────

# Server
PORT=3000
NODE_ENV=development

# Allowed frontend origin (your landing page URL)
# For local dev: http://localhost:5500
# For production: https://yourdomain.com
ALLOWED_ORIGIN=http://localhost:5500

# Google Sheets
# Your spreadsheet ID — found in the sheet URL:
# https://docs.google.com/spreadsheets/d/SPREADSHEET_ID/edit
GOOGLE_SPREADSHEET_ID=your_spreadsheet_id_here

# The exact name of the sheet tab inside your spreadsheet
GOOGLE_SHEET_NAME=Leads

# Google Service Account credentials
# Option A (recommended for production): path to the JSON key file
GOOGLE_SERVICE_ACCOUNT_KEY_PATH=./google-credentials.json

# Option B: paste the full JSON as a single-line string (useful for hosting platforms)
# GOOGLE_SERVICE_ACCOUNT_KEY_JSON={"type":"service_account","project_id":"..."}
